	quest.7219E2A3F6F8C58E.title: "Overworld Nether"
	quest.72362C507A0A5F9B.quest_desc: [
		"From larger than life mountains, to redstone puzzles, ore extractions, transportation logistics, and epic fights- Exploration in this world will serve you well."
		""
		"Before you begin a journey across the world- It is important that you create a veihicle capable of traversing such a distance."
		""
		"Structures in the world are further apart than ever."
		""
		"Biomes stretch taller and wider than before."
		""
		"Landmasses and continents arose from the seas."
		""
		"Mystical biomes and harrowing creatures sprung forth in the new expanse."
	]
	quest.72362C507A0A5F9B.quest_subtitle: "Learn about what the world has to offer"
	quest.72362C507A0A5F9B.title: "Explore!"
