	quest.7460A85443533B56.quest_subtitle: "Obtain a Heating Coil"
	quest.7460A85443533B56.title: "More- Artifical Heating?"
	quest.749FF26570D964EC.quest_desc: [
		"Asurine resource vents are often found in &nfrozen biomes&r."
		""
		"They're quite rare, but the processing capabilities from one alone are astronomical!"
		"{image:minecraft:block/lava_still width:25 height:25 align:center}"
		"{image:essential:textures/menu/arrow_down.png width:25 height:25 align:center}"
		"{image:blazinghot:fluid/molten_zinc_still width:25 height:25 align:center}"
		"To activate an ore vent, you must explode it first!"
		"Then, supply a lava source block in contact with the vent or an orestone produced by the vent in a 3 block radius, to create an instant version of the orestone!"
		"Mine and process from there!"
	]
	quest.749FF26570D964EC.quest_subtitle: "Find an Asurine Ore Vent"
	quest.749FF26570D964EC.title: "Asure Adventure"
