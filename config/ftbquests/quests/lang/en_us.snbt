	quest.6D27EFDDE48DABA1.quest_subtitle: "Explore the Expansion in the Forests!"
	quest.6D27EFDDE48DABA1.title: "Forested Frolic"
	quest.6D8532E4F3E86AB0.quest_desc: [
		"Thrusters are the absolute pinnacle of propulsion we have available."
		"Thrusters require gasoline or another liquid fuel to be supplied in order to produce thrust, see fuel stats by hovering over a bucket of the fuel and holding [shift]"
		""
		"To work:"
		"- Pump fuel directly into the copper interface"
		"- Supply a redstone signal, analog levels will produce less thrust"
		""
		"&oPonder for more details&r"
		"{image:createpropulsion:textures/particle/plume/plume5_e.png width:25 height:25 align:center}"
	]
