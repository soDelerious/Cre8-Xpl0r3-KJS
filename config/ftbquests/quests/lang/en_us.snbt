	quest.76EBE455344AE32C.quest_desc: [
		""
		"&nPLEASE READ ALL OF THIS!&r"
		""
		"Hi! Welcome to Cre8; Xpl0r3!"
		""
		"This Modpack is a Create+ X Vanilla+ Mashup pack based on exploration, heavily modified to provide the most fluent and immersive experience possible."
		""
		"This pack is also designed as a sort of introduction to Create/Aeronautics!"
		""
		"Happy Exploring! "
		""
		"{@pagebreak}"
		""
		"[Note]: Quests with an sqare shape only require 1 of it's dependencies completed to be able to be startable"
		""
		"A quick guide to navigating:  Use JEI (Just Enough Items; the large wall of items visible to the right of your inventory) to find crafting recipes. left click to see how to craft the item, right click for recipes it's in."
		""
		"{image:overpacked:item/giant_backpack width:25 height:25 align:center}"
		""
		"Holding [W] on most create mod items will allow the user to engage in a &oponder&r."
		"This shows the player a visible depiction of how to use a item/block without the use of an online wiki. Use this and what you've learned about JEI to complete future tasks and learn about create!"
	]
	quest.76EBE455344AE32C.quest_subtitle: "Left click on quests to open descriptions."
