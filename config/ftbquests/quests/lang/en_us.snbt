	quest.6BFCBF8D170B3370.quest_desc: [
		"Had issues with factories overproducing? This is your fix!"
		""
		"Threshold switches will produce a configurable redstone signal based off of a containers available/used inventory. The intended effect of this is to be used to shut off/slow down factories that are producing too much."
		""
		"&oPonder for more details&r"
	]
	quest.6BFCBF8D170B3370.quest_subtitle: "Obtain a threshold switch"
	quest.6BFCBF8D170B3370.title: "I have been dreaming about this."
	quest.6C6C650980F7492A.quest_desc: [
		"Mechanical Saws will harvest entire tress from moving contraptions and place into stoarge bins, however they do not replant trees."
