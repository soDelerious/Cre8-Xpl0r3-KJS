	quest.728509E5032FD774.title: "Plains Massacre"
	quest.72964910579FBFB1.quest_desc: [
		"Craft a mixer and shapelessly craft an item! Powering the mixer over a basin allows items without a shaped crafting recipe to be merged together!"
		"[Trick]: Mixing 1 iron/zinc nugget and 1 andesite also makes an alloy, a much cheaper recipe to what you've been doing up till now."
		""
		""
		"{image:create:item/whisk width:25 height:25 align:center}"
