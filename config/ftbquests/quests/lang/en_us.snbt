	quest.7A0E09DAC8F08980.quest_desc: [
		"Simply mix the metal in a superheated basin to melt!"
		""
		"Melting metals has significant advantages! Melting raw material (raw/crushed iron/gold/etc) produces almost double that of melting down a single ingot- allowing you to double your production!"
		""
		"&oOpen JEI to observe recipes&r"
	]
	quest.7A0E09DAC8F08980.quest_subtitle: "Melt down various metals"
