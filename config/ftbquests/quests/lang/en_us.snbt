	quest.6D9AFAA9FB9C4887.quest_subtitle: "Obtain a bucket of Oxidizer"
	quest.6D9AFAA9FB9C4887.title: "Complete Combustion"
	quest.6DCB2B0EC68ECCFF.quest_desc: [
		"Sanding Catalysts are dropped by Sirok the sandworm, find his summon in desert/badlands biomes!"
